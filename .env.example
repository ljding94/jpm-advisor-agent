# ============ LLM provider ============
# Pick one of: openrouter (default), openai, anthropic, ollama
LLM_PROVIDER=openrouter

# OpenRouter — get a key at https://openrouter.ai
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Override the free-tier dropdown in app.py with comma-separated slugs.
# Useful when the deploy uses a restricted key — the slugs here should match
# exactly the models you've allowed in the OpenRouter dashboard.
# Example:
# OPENROUTER_FREE_MODELS=google/gemma-4-31b:free,minimax/minimax-m2.5:free
OPENROUTER_FREE_MODELS=

# OpenAI native (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL= (optional — for Azure or custom gateway)

# Anthropic native (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama local (when LLM_PROVIDER=ollama) — start with `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ============ Embeddings ============
# Pick one of: auto (default), openrouter, openai, local
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=openai/text-embedding-3-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============ Storage ============
CHROMA_PATH=data/chroma

# ============ Streamlit deployment ============
# Optional shared password for the Streamlit app. If unset, the app is open.
# Set this when deploying publicly. Use Streamlit Cloud "Secrets" UI in production
# (the app reads from st.secrets first, then this env var).
APP_PASSWORD=
